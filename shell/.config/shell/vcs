# Walk up to find .hg without spawning hg (avoids Python startup cost)
__find_hg_root() {
    local dir=$PWD
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.hg" ]; then
            echo "$dir"
            return 0
        fi
        dir=${dir%/*}
        [ -z "$dir" ] && dir=/
    done
    return 1
}
